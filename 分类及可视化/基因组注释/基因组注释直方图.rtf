dt=fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/meta/class/metaqtl_significant_final_reclassified.txt")\
\
setnames(dt, c("V22", "V23", "V24"), c("gene", "genomic_region", "alu"))\
\
library(data.table)\
library(ggplot2)\
\
# 1. \uc0\u35774 \u32622 \u36335 \u24452 \u19982 \u25968 \u25454 \u20934 \u22791 \
out_dir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/meta/class/ediste_anno/"\
if(!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)\
\
# \uc0\u21076 \u38500  NA \u21306 \u22495 \u25968 \u25454 \
dt_clean <- dt[!is.na(genomic_region) & genomic_region != "NA" & genomic_region != ""]\
\
# --- \uc0\u31532 \u19968 \u27493 \u65306 \u25552 \u21462  Universe \u32972 \u26223  ---\
universe_dist <- dt_clean[, .N, by = genomic_region]\
universe_dist[, Percentage := (N / sum(N)) * 100]\
universe_dist[, Source := "Universe"]\
\
# --- \uc0\u31532 \u20108 \u27493 \u65306 \u25552 \u21462 \u22235 \u20010 \u23454 \u39564 \u32452 \u24182 \u27719 \u24635  ---\
target_groups <- c("Consistent_LowHet", "Consistent_HighHet", "Opposite_LowHet", "Opposite_HighHet")\
\
# \uc0\u24490 \u29615 \u25552 \u21462 \u27599 \u32452 \u30340 \u20998 \u24067 \
target_dist_list <- lapply(target_groups, function(g) \{\
  group_dt <- dt_clean[Final_Class == g, .N, by = genomic_region]\
  if(nrow(group_dt) > 0) \{\
    group_dt[, Percentage := (N / sum(N)) * 100]\
    group_dt[, Source := g]\
    return(group_dt)\
  \}\
  return(NULL)\
\})\
\
# \uc0\u21512 \u24182 \u25152 \u26377 \u25968 \u25454  (Universe + \u25152 \u26377 \u26377 \u25928 \u23454 \u39564 \u32452 )\
plot_all_data <- rbindlist(c(list(universe_dist), target_dist_list))\
\
# --- \uc0\u31532 \u19977 \u27493 \u65306 \u35774 \u32622 \u22240 \u23376 \u39034 \u24207 \u21644 \u39068 \u33394  ---\
# \uc0\u22266 \u23450  Source \u30340 \u39034 \u24207 \u65292 \u30830 \u20445  Universe \u22312 \u26368 \u21069 \u38754 \
plot_all_data$Source <- factor(plot_all_data$Source, levels = c("Universe", target_groups))\
\
# \uc0\u20351 \u29992 \u24744 \u20043 \u21069 \u30340 \u33707 \u20848 \u36842 \u33394 \u31995 \u25193 \u23637 \u65292 \u25110 \u32773 \u33258 \u23450 \u20041 \u19968 \u22871 \u23545 \u27604 \u33394 \
# \uc0\u36825 \u37324 \u25105 \u20026 \u24744 \u21305 \u37197 \u20102  5 \u31181 \u21327 \u35843 \u30340 \u39068 \u33394 \
group_colors <- c(\
  "Universe"           = "#D3D3D3", # \uc0\u27973 \u28784 \u33394 \u32972 \u26223 \
  "Consistent_LowHet"  = "#859B97", # \uc0\u28784 \u32511 \u33394 \
  "Consistent_HighHet" = "#9BB0BD", # \uc0\u34013 \u28784 \u33394 \
  "Opposite_LowHet"    = "#A8C7CE", # \uc0\u27973 \u38738 \u33394 \
  "Opposite_HighHet"   = "#E0B48C"  # \uc0\u27973 \u35088 \u33394 \
)\
\
# --- \uc0\u31532 \u22235 \u27493 \u65306 \u32472 \u21046 \u20116 \u20010  Bar \u24182 \u21015 \u30340 \u32452 \u21512 \u22270  ---\
# \uc0\u35774 \u32622 \u25991 \u23383 \u26631 \u27880 \u30340 \u20559 \u31227 \u23485 \u24230 \u65288 \u24517 \u39035 \u19982  geom_bar \u30340  dodge \u23485 \u24230 \u19968 \u33268 \u65289 \
dodge_width <- 0.9\
\
p_combined <- ggplot(plot_all_data, aes(x = genomic_region, y = Percentage, fill = Source)) +\
  # 1. \uc0\u32472 \u21046 \u26609 \u29366 \u22270 \
  geom_bar(stat = "identity", position = position_dodge(dodge_width), color = "black", width = 0.8) +\
  \
  # 2. \uc0\u28155 \u21152 \u25968 \u20540 \u26631 \u27880 \
  geom_text(\
    aes(label = sprintf("%.1f%%", Percentage)), \
    position = position_dodge(width = dodge_width), \
    vjust = -0.5,            # \uc0\u25991 \u23383 \u26174 \u31034 \u22312 \u26609 \u23376 \u19978 \u26041 \
    hjust = 0.5,             # \uc0\u27700 \u24179 \u23621 \u20013 \
    size = 2.8,              # \uc0\u35843 \u25972 \u23383 \u20307 \u22823 \u23567 \u20197 \u38450 \u37325 \u21472 \
    fontface = "bold",\
    color = "black"          # \uc0\u24378 \u21046 \u40657 \u33394 \u65292 \u28165 \u26224 \u24230 \u26356 \u39640 \
  ) +\
  \
  scale_fill_manual(values = group_colors) +\
  theme_classic() +\
  labs(\
    title = "Genomic Region Distribution across Meta-QTL Classes",\
    x = "Genomic Region",\
    y = "Percentage of edSites (%)",\
    fill = "Group"\
  ) +\
  theme(\
    axis.text.x = element_text(angle = 45, hjust = 1, face = "bold", size = 11, color = "black"),\
    axis.text.y = element_text(color = "black", size = 11),\
    legend.position = "top",\
    plot.title = element_text(hjust = 0.5, size = 15, face = "bold")\
  ) +\
  # 3. \uc0\u36866 \u24403 \u22686 \u21152  Y \u36724 \u19978 \u38480 \u65292 \u38450 \u27490 \u26631 \u31614 \u36229 \u30028 \u34987 \u20999 \u25481 \
  scale_y_continuous(expand = expansion(mult = c(0, 0.2)))\
\
# \uc0\u20445 \u23384 \u26102 \u24314 \u35758 \u35843 \u23485 \u19968 \u28857 \u65292 5\u20010 \u26609 \u23376 +\u25991 \u23383 \u38656 \u35201 \u26356 \u22810 \u21628 \u21560 \u31354 \u38388 \
ggsave(paste0(out_dir, "Region_Dist_Combined_with_Labels.pdf"), p_combined, width = 14, height = 7)\
\
cat("\uc0\u20840 \u32452 \u21512 \u22270 \u24050 \u25104 \u21151 \u20445 \u23384 \u33267 :", out_dir, "\\n")\
