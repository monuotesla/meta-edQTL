\f0 \
path <- "/zs32/home/ynuoma/edQTL/vcf_out/meta/"\
# 
\f1 \'ce\'d2\'c3\'c7\'d6\'bb\'b9\'d8\'d7\'a2\'d5\'e2\'c1\'bd\'d7\'e9
\f0 \
target_groups <- c("Consistent_LowHet", "Opposite_HighHet")\
\
all_data <- lapply(target_groups, function(g) \{\
  file <- paste0(path, g, "_with_Fst.txt")\
  if (file.exists(file)) \{\
    dt_sub <- fread(file, header = FALSE)\
    setnames(dt_sub, c("rsid", "edSite", "edSNP", "VCF_ID", "Fst"))\
    dt_sub[, Group := g]\
    return(dt_sub)\
  \}\
\})\
\
plot_df <- rbindlist(all_data)\
\
# 2. 
