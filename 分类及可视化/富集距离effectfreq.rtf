\f1 \'bd\'e1\'ba\'cf\'a3\'ac\'b2\'a2\'ca\'d6\'b6\'af\'b1\'ea\'d7\'a2\'be\'f9\'d6\'b5\'b5\'e3
\f0 \
p_fst_2 <- ggplot(plot_df, aes(x = Group, y = Fst, fill = Group)) +\
  geom_violin(trim = FALSE, alpha = 0.6, color = NA) +\
  geom_boxplot(width = 0.15, outlier.shape = NA, color = "black", fill = "white") +\
  # 
\f1 \'b9\'d8\'bc\'fc\'b2\'bd\'d6\'e8\'a3\'ba\'d4\'da\'cd\'bc\'d6\'d0\'cc\'ed\'bc\'d3\'be\'f9\'d6\'b5\'b5\'e3\'a3\'a8\'ba\'ec\'c9\'ab\'c1\'e2\'d0\'ce\'a3\'a9
\f0 \
  stat_summary(fun = mean, geom = "point", shape = 18, size = 4, color = "red") +\
  # 
\f1 \'d4\'da\'be\'f9\'d6\'b5\'b5\'e3\'c5\'d4\'b1\'df\'b1\'ea\'d7\'a2\'ca\'fd\'d6\'b5
\f0 \
  geom_text(data = mu, aes(x = Group, y = mean_val, label = paste("Mean:", round(mean_val, 4))),\
            vjust = -1.2, color = "red", fontface = "bold", size = 5) +\
  # 
\f1 \'c9\'e8\'d6\'c3\'c5\'e4\'c9\'ab
\f0 \
  scale_fill_manual(values = c("Consistent_LowHet" = "#4DBBD5", "Opposite_HighHet" = "#00A087")) +\
  theme_bw() +\
  labs(\
    title = "Population Differentiation: Consistent vs. Opposite",\
    subtitle = "Mean Fst indicated by red diamond",\
    x = "", \
    y = "Fst (Consistent_LowHet vs Opposite_HighHet)"\
  ) +\
  theme(\
    axis.title = element_text(size = 16, face = "bold"),\
    axis.text = element_text(size = 14, color = "black"),\
    plot.title = element_text(size = 18, hjust = 0.5),\
    legend.position = "none"\
  ) +\
  # 
\f1 \'cc\'ed\'bc\'d3\'c1\'bd\'d7\'e9\'bc\'e4\'b2\'ee\'d2\'ec
\f0  P 
