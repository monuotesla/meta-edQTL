\f0 \
mu <- plot_df[, .(mean_val = mean(Fst, na.rm = TRUE)), by = Group]\
print("
\f1 \'b8\'f7\'d7\'e9\'be\'f9\'d6\'b5\'a3\'ba
\f0 ")\
print(mu)\
\
# 3. 
