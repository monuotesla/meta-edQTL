\f1 \'a3\'a8\'c0\'b4\'d7\'d4\'d4\'ad
\f0  dt
\f1 \'a3\'a9\'a3\'ba
\f0 \
ld_dt <- merge(\
  ld_dt,\
  unique(dt_sub[, .(rsid, HetChiSq)], by = "rsid"),\
