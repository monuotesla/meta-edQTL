  geom_text(data = means_log, aes(x = Final_Class, y = mean_val, label = sprintf("%.3f", mean_val)),\
            vjust = -1.5, size = 5, fontface = "bold", inherit.aes = FALSE) +\
  stat_compare_means(comparisons = list(\
    c("Consistent_LowHet", "Consistent_HighHet"),\
    c("Consistent_HighHet", "Opposite_HighHet"),\
    c("Consistent_LowHet", "Opposite_HighHet")\
  ), label = "p.signif", method = "wilcox.test", size = 7) +\
  scale_fill_brewer(palette = "Set1") +\
  theme_classic(base_size = 16) +\
  labs(y = "|Delta Log10(L2 + 1)|", x = NULL, title = "Log-Scaled LD Divergence by Class") +\
  theme(legend.position = "none", axis.text.x = element_text(angle = 30, hjust = 1, face = "bold"))\
\
