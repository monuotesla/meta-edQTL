\
# 
\f1 \'bc\'c6\'cb\'e3\'be\'f9\'d6\'b5\'d3\'c3\'d3\'da\'b1\'ea\'d7\'a2
\f0 \
means_log <- ld_sub[delta_logL2 <= 1, .(mean_val = mean(delta_logL2, na.rm = TRUE)), by = Final_Class]\
\
p_box_log <- ggplot(ld_sub[delta_logL2 <= 1], aes(x = Final_Class, y = delta_logL2, fill = Final_Class)) +\
  geom_boxplot(outlier.alpha = 0.1, outlier.size = 0.5, width = 0.5) +\
  stat_summary(fun = mean, geom = "point", shape = 23, size = 4, fill = "white") +\
  # 
\f1 \'b1\'ea\'d7\'a2\'be\'f9\'d6\'b5\'ca\'fd\'d6\'b5
