cor_by_class <- ld_dt[\
  , .(\
    rho = cor(delta_L2, HetChiSq, method = "spearman", use = "complete.obs"),\
    p   = cor.test(delta_L2, HetChiSq, method = "spearman")$p.value\
  ),\
  by = Final_Class\
]\
\
