run_go_bp <- function(genes) \{\
  enrichGO(\
    gene          = genes,\
    universe      = gene_universe,\
    OrgDb         = org.Hs.eg.db,\
    keyType       = "SYMBOL",\
    ont           = "BP",\
    pAdjustMethod = "BH",\
    pvalueCutoff  = 0.05,\
    qvalueCutoff  = 0.2,\
    readable      = TRUE\
  )\
\}\
\
