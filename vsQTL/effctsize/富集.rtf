library(data.table)\
library(clusterProfiler)\
library(org.Hs.eg.db)\
library(ggplot2)\
\
# =========================\
# 1\uc0\u65039 \u8419  \u35835 \u21462  gene\
# =========================\
read_set <- function(f) unique(scan(f, what="char"))\
\
ed <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/ed.uniq")\
e  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/eq.uniq")\
s  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/s.uniq")\
p  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/p.uniq")\
\
gene_list <- list(ed=ed, e=e, s=s, p=p)\
\
# \uc0\u36755 \u20986 \u30446 \u24405 \
out_dir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/\uc0\u23500 \u38598 /"\
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)\
\
# =========================\
# 2\uc0\u65039 \u8419  \u23500 \u38598 \u20989 \u25968 \
# =========================\
run_go <- function(genes, label) \{\
\
  cat("Running:", label, "\\n")\
\
  # \uc0\u36716 ENTREZ\
  gene_map <- bitr(\
    genes,\
    fromType="SYMBOL",\
    toType="ENTREZID",\
    OrgDb=org.Hs.eg.db\
  )\
\
  if (is.null(gene_map) || nrow(gene_map) < 5) return(NULL)\
\
  ego <- enrichGO(\
    gene = unique(gene_map$ENTREZID),\
    OrgDb = org.Hs.eg.db,\
    ont = "BP",\
    pvalueCutoff = 1,\
    qvalueCutoff = 1,\
    readable = TRUE\
  )\
\
  dt <- as.data.table(ego)\
\
  fwrite(dt, paste0(out_dir, label, "_GO_BP.txt"), sep="\\t")\
\
  return(dt)\
\}\
\
# =========================\
# 3\uc0\u65039 \u8419  \u36305 \u22235 \u32452 \
# =========================\
go_res <- lapply(names(gene_list), function(x) \{\
  run_go(gene_list[[x]], x)\
\})\
names(go_res) <- names(gene_list)\
\
# =========================\
# 4\uc0\u65039 \u8419  ratio\u35299 \u26512 \
# =========================\
parse_ratio <- function(x) \{\
  sapply(strsplit(x, "/"), function(y) as.numeric(y[1]) / as.numeric(y[2]))\
\}\
\
# =========================\
# 5\uc0\u65039 \u8419  \u21462 top4\
# =========================\
get_top <- function(dt, label) \{\
\
  if (is.null(dt)) return(NULL)\
\
  dt[, geneRatio := parse_ratio(GeneRatio)]\
  dt[, bgRatio   := parse_ratio(BgRatio)]\
  dt[, FE := geneRatio / bgRatio]\
\
  dt <- dt[order(pvalue)][1:4]\
  dt[, Group := label]\
\
  dt[, .(Description, Group, pvalue, FE)]\
\}\
\
top_list <- mapply(get_top, go_res, names(go_res), SIMPLIFY = FALSE)\
top_all <- rbindlist(top_list)\
\
# =========================\
# 6\uc0\u65039 \u8419  \u26500 \u24314 \u30697 \u38453 \
# =========================\
all_pathways <- unique(top_all$Description)\
\
plot_dt <- CJ(\
  Description = all_pathways,\
  Group = names(gene_list)\
)\
\
plot_dt <- merge(plot_dt, top_all, by=c("Description","Group"), all.x=TRUE)\
\
plot_dt[is.na(pvalue), pvalue := 1]\
plot_dt[is.na(FE), FE := 0]\
\
# \uc0\u25490 \u24207 \
plot_dt[, Description := factor(Description)]\
\
# =========================\
# 7\uc0\u65039 \u8419  \u30011 \u22270 \
# =========================\
p <- ggplot(plot_dt, aes(x=Group, y=Description)) +\
  \
  geom_point(aes(size=FE, fill=pvalue),\
             shape=21, color="black") +\
  \
  scale_fill_gradient(\
    low="red",\
    high="lightgrey",\
    limits=c(0,0.1)\
  ) +\
  \
  scale_size(range=c(3,10)) +\
  \
  theme_classic(base_size=14) +\
  \
  labs(\
    title="GO enrichment comparison (ed vs e vs s vs p)",\
    x=NULL,\
    y=NULL\
  )\
\
ggsave(\
  paste0(out_dir, "GO_top4_compare.pdf"),\
  p,\
  width=10,\
  height=6\
)\
\
\
