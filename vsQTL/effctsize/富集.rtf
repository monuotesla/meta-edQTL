library(data.table)\
library(clusterProfiler)\
library(org.Hs.eg.db)\
\
# =========================\
# 1\uc0\u65039 \u8419  \u35835  gene\
# =========================\
read_set <- function(f) unique(scan(f, what="char"))\
\
ed <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/ed.uniq")\
e  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/eq.uniq")\
s  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/s.uniq")\
p  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/p.uniq")\
\
# =========================\
# 2\uc0\u65039 \u8419  overlap\
# =========================\
ed_e <- intersect(ed, e)\
ed_s <- intersect(ed, s)\
ed_p <- intersect(ed, p)\
\
overlap_list <- list(\
  ed_e = ed_e,\
  ed_s = ed_s,\
  ed_p = ed_p\
)\
\
# =========================\
# 3\uc0\u65039 \u8419  \u36755 \u20986 \u30446 \u24405 \
# =========================\
out_dir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/\uc0\u23500 \u38598 /overlap/"\
dir.create(out_dir, showWarnings=FALSE, recursive=TRUE)\
\
# =========================\
# 4\uc0\u65039 \u8419  \u23500 \u38598 \u20989 \u25968 \
# =========================\
run_go <- function(genes, label) \{\
\
  cat("Running:", label, " N=", length(genes), "\\n")\
\
  gene_map <- bitr(\
    genes,\
    fromType="SYMBOL",\
    toType="ENTREZID",\
    OrgDb=org.Hs.eg.db\
  )\
\
  if (is.null(gene_map) || nrow(gene_map) < 5) \{\
    cat("Too few genes:", label, "\\n")\
    return(NULL)\
  \}\
\
  ego <- enrichGO(\
    gene = unique(gene_map$ENTREZID),\
    OrgDb = org.Hs.eg.db,\
    ont = "BP",\
    pAdjustMethod = "BH",\
    pvalueCutoff = 1,\
    qvalueCutoff = 1,\
    readable = TRUE\
  )\
\
  dt <- as.data.table(ego)\
\
  # \uc0\u20445 \u23384 \u23436 \u25972 \u32467 \u26524 \
  fwrite(dt, paste0(out_dir, label, "_GO.txt"), sep="\\t")\
\
  # \uc0\u21462  top5\
  dt_top <- dt[order(p.adjust)][1:5]\
\
  fwrite(dt_top, paste0(out_dir, label, "_GO_top5.txt"), sep="\\t")\
\
  return(dt_top)\
\}\
\
# =========================\
# 5\uc0\u65039 \u8419  \u36816 \u34892 \
# =========================\
res_list <- lapply(names(overlap_list), function(x) \{\
  run_go(overlap_list[[x]], x)\
\})\
names(res_list) <- names(overlap_list)\
\
cat("All overlap enrichment done.\\n")\
\
