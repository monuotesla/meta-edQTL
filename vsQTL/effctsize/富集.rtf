\
plot_top5 <- function(ego, title, color) \{\
  df <- as.data.frame(ego)\
  df <- df %>% arrange(p.adjust) %>% head(5)\
\
  ggplot(df, aes(\
    x = reorder(Description, -log10(p.adjust)),\
    y = -log10(p.adjust)\
  )) +\
    geom_bar(stat = "identity", fill = color) +\
    coord_flip() +\
    theme_bw() +\
    labs(\
      title = title,\
      x = "",\
      y = "-log10(adj. P)"\
    )\
\}\
\
p_eGene  <- plot_top5(ego_eGene,  "GO BP enrichment: eGenes",  "#4DBBD5")\
p_edGene <- plot_top5(ego_edGene, "GO BP enrichment: edGenes", "#E64B35")\
p_pGene  <- plot_top5(ego_pGene,  "GO BP enrichment: pGenes",  "#00A087")\
\
p_eGene\
p_edGene\
p_pGene\
