###########snp \uc0\u26609 \u29366 \u22270 \
library(ggplot2)\
library(scales)\
\
universe <- unique(c(ed, e, p))\
\
classify <- function(x) \{\
  in_ed <- x %in% ed\
  in_e  <- x %in% e\
  in_p  <- x %in% p\
\
  if (in_ed & !in_e & !in_p) return("ed-only")\
  if (!in_ed & in_e & !in_p) return("e-only")\
  if (!in_ed & !in_e & in_p) return("p-only")\
  if (in_ed & in_e & !in_p) return("ed \uc0\u8745  e")\
  if (in_ed & !in_e & in_p) return("ed \uc0\u8745  p")\
  if (!in_ed & in_e & in_p) return("e \uc0\u8745  p")\
  if (in_ed & in_e & in_p) return("ed \uc0\u8745  e \u8745  p")\
\}\
\
df.snp <- as.data.frame(table(sapply(universe, classify)))\
colnames(df.snp) <- c("Category", "Count")\
df.snp$Proportion <- df.snp$Count / sum(df.snp$Count)\
\
df.snp$Category <- factor(\
  df.snp$Category,\
  levels = c(\
    "ed-only", "e-only", "p-only",\
    "ed \uc0\u8745  e", "ed \u8745  p", "e \u8745  p",\
    "ed \uc0\u8745  e \u8745  p"\
  )\
)\
\
ggplot(df.snp, aes(x = Category, y = Proportion, fill = Category)) +\
  geom_bar(stat = "identity", width = 0.7) +\
  geom_text(\
    aes(label = percent(Proportion, accuracy = 0.1)),\
    vjust = -0.3, size = 3.6\
  ) +\
  scale_y_continuous(\
    limits = c(0, 0.15),\
    labels = percent_format(accuracy = 1),\
    expand = expansion(mult = c(0, 0.05))\
  ) +\
  theme_bw() +\
  theme(\
    legend.position = "none",\
    axis.text.x = element_text(angle = 45, hjust = 1)\
  )\
\
ggsave("SNP_universe_barplot.pdf", width = 7, height = 4)\
