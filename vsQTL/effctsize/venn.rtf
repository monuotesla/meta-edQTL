\
library(ggplot2)\
\
# \uc0\u35835 \u20837  gene sets\
ed <- scan("col1.uniq", what = character())\
eq <- scan("col2.uniq", what = character())\
pq <- scan("col3.uniq", what = character())\
\
# universe\
universe <- sort(unique(c(ed, eq, pq)))\
N <- length(universe)\
\
# \uc0\u21028 \u23450 \u27599 \u20010  gene \u23646 \u20110 \u21738 \u19968 \u31867 \
classify <- function(g) \{\
  in_ed <- g %in% ed\
  in_eq <- g %in% eq\
  in_pq <- g %in% pq\
\
  if (in_ed & !in_eq & !in_pq) return("ed-only")\
  if (!in_ed & in_eq & !in_pq) return("e-only")\
  if (!in_ed & !in_eq & in_pq) return("p-only")\
  if (in_ed & in_eq & !in_pq) return("ed \uc0\u8745  e")\
  if (in_ed & !in_eq & in_pq) return("ed \uc0\u8745  p")\
  if (!in_ed & in_eq & in_pq) return("e \uc0\u8745  p")\
  if (in_ed & in_eq & in_pq) return("ed \uc0\u8745  e \u8745  p")\
\}\
\
category <- sapply(universe, classify)\
\
df <- as.data.frame(table(category))\
colnames(df) <- c("Category", "Count")\
df$Proportion <- df$Count / N\
\
# \uc0\u25490 \u24207 \u65288 \u25353 \u29983 \u29289 \u23398 \u36923 \u36753 \u65292 \u19981 \u26159 \u23383 \u27597 \u65289 \
df$Category <- factor(\
  df$Category,\
  levels = c(\
    "ed-only", "e-only", "p-only",\
    "ed \uc0\u8745  e", "ed \u8745  p", "e \u8745  p",\
    "ed \uc0\u8745  e \u8745  p"\
  )\
)\
\
# \uc0\u20445 \u23384 \u32479 \u35745 \u34920 \u65288 \u35770 \u25991 \u34917 \u20805 \u26448 \u26009 \u65289 \
write.table(\
  df,\
  file = "ed_eq_pqtl_universe_partition.txt",\
  sep = "\\t",\
  quote = FALSE,\
  row.names = FALSE\
)\
\
