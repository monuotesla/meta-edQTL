\f0\fs36 \cf0 # ===============================\
# ed / e / p QTL gene overlap\
# ===============================\
\
library(VennDiagram)\
library(grid)\
\
setwd("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/")\
# 1. \uc0\u35835 \u20837  gene sets\
ed  <- scan("col1.uniq", what = character())\
eq  <- scan("col2.uniq", what = character())\
pq  <- scan("col3.uniq", what = character())\
\
# 2. \uc0\u22522 \u26412 \u25968 \u37327 \
n_ed <- length(ed)\
n_eq <- length(eq)\
n_pq <- length(pq)\
\
# 3. \uc0\u20132 \u38598 \
ed_eq    <- intersect(ed, eq)\
ed_pq    <- intersect(ed, pq)\
eq_pq    <- intersect(eq, pq)\
ed_eq_pq <- Reduce(intersect, list(ed, eq, pq))\
\
# 4. \uc0\u21508 \u21306 \u22495 \u25968 \u37327 \u65288 Venn \u38656 \u35201 \'93\u32431 \u21306 \u22495 \'94\u65289 \
n_ed_only <- length(setdiff(ed, union(eq, pq)))\
n_eq_only <- length(setdiff(eq, union(ed, pq)))\
n_pq_only <- length(setdiff(pq, union(ed, eq)))\
\
n_ed_eq_only <- length(setdiff(ed_eq, pq))\
n_ed_pq_only <- length(setdiff(ed_pq, eq))\
n_eq_pq_only <- length(setdiff(eq_pq, ed))\
\
n_all <- length(ed_eq_pq)\
\
# 5. \uc0\u27604 \u20363 \u65288 \u20197 \u21508 \u33258 \u38598 \u21512 \u20026  denominator\u65289 \
pct <- function(x, total) round(100 * x / total, 2)\
\
# 6. \uc0\u25171 \u21360 \u32479 \u35745 \u34920 \u65288 \u24378 \u28872 \u24314 \u35758 \u20445 \u23384 \u65289 \
stat <- data.frame(\
  Category = c(\
    "ed-only", "e-only", "p-only",\
    "ed \uc0\u8745  e", "ed \u8745  p", "e \u8745  p",\
    "ed \uc0\u8745  e \u8745  p"\
  ),\
  Count = c(\
    n_ed_only,\
    n_eq_only,\
    n_pq_only,\
    n_ed_eq_only,\
    n_ed_pq_only,\
    n_eq_pq_only,\
    n_all\
  )\
)\
\
write.table(stat,\
            file = "ed_eq_pqtl_overlap_counts.txt",\
            sep = "\\t",\
            quote = FALSE,\
            row.names = FALSE)\
\
# 7. \uc0\u30011  Venn \u22270 \u65288 \u25968 \u37327 \u65289 \
venn.plot <- draw.triple.venn(\
  area1 = n_ed,\
  area2 = n_eq,\
  area3 = n_pq,\
  n12 = length(ed_eq),\
  n13 = length(ed_pq),\
  n23 = length(eq_pq),\
  n123 = n_all,\
\
  # === \uc0\u25913 \u36825 \u37324  ===\
  category = c("edGene", "eGene", "pGene"),\
\
  cat.pos  = c(-20, 20, -120),   # \uc0\u31532 \u19977 \u20010 \u21521 \u19979 \
  cat.dist = c(0.05, 0.05, 0.05),  # \uc0\u31532 \u19977 \u20010 \u31245 \u24494 \u36828 \u19968 \u28857 \
\
\
\
fill = c("#FADADD",  # baby pink\
         "#D6EAF8",  # baby blue\
         "#D5F5E3")  ,\
  alpha = 0.6,\
  cex = 2,\
  cat.cex = 2\
)\
\
pdf("ed_e_p_gene_venn2.pdf", width = 5, height = 5)\
grid.draw(venn.plot)\
dev.off()\
\
\

\fs72 \cf2 ######################\uc0\u26609 \u29366 \u22270 \cf0 \

\fs36  #fill = c("#F6C1CC",  # \uc0\u31881 \u65288 edGene\u65289 \
