library(data.table)\
library(ggplot2)\
library(ggpubr)\
library(dplyr)\
\
# ======================\
# \uc0\u36755 \u20986 \u30446 \u24405 \
# ======================\
outdir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/effcet"\
dir.create(outdir, showWarnings = FALSE, recursive = TRUE)\
\
# ======================\
# 1\uc0\u65039 \u8419  \u35835 \u20837 \u25968 \u25454 \
# ======================\
ed <- fread(file.path(outdir, "edqtl_pair_beta.txt"), header = FALSE)\
pq <- fread(file.path(outdir, "pqtl_pair_beta.txt"), header = FALSE)\
eq <- fread(file.path(outdir, "eqtl_pair_beta.txt"), header = FALSE)\
sq <- fread(file.path(outdir, "sqtl_pair_beta.txt"), header = FALSE)\
\
setnames(ed, c("pair", "beta"))\
setnames(pq, c("pair", "beta"))\
setnames(eq, c("pair", "beta"))\
setnames(sq, c("pair", "beta"))\
\
# ======================\
# 2\uc0\u65039 \u8419  |effect|\
# ======================\
ed_eff <- data.table(type = "edQTL", effect = abs(as.numeric(ed$beta)))\
pq_eff <- data.table(type = "pQTL", effect = abs(as.numeric(pq$beta)))\
eq_eff <- data.table(type = "eQTL", effect = abs(as.numeric(eq$beta)))\
sq_eff <- data.table(type = "sQTL", effect = abs(as.numeric(sq$beta)))\
\
dat <- rbind(ed_eff, eq_eff, sq_eff, pq_eff)\
dat <- dat[!is.na(effect)]\
\
# ======================\
# \uc0\u21435 \u26497 \u31471 \u20540 \
# ======================\
dat <- dat[effect < quantile(effect, 0.99)]\
\
# ======================\
# \uc0\u55357 \u56613  \u22266 \u23450 \u39034 \u24207 \u65288 \u20851 \u38190 \u20462 \u25913 \u65289 \
# ======================\
dat[, type := factor(type, levels = c("edQTL","eQTL","sQTL","pQTL"))]\
\
# ======================\
# 3\uc0\u65039 \u8419  \u35745 \u31639 \u22343 \u20540 \u65288 \u19981 \u20877 \u25490 \u24207 \u65289 \
# ======================\
mean_df <- dat[, .(mean_effect = mean(effect)), by = type]\
\
# ======================\
# 4\uc0\u65039 \u8419  \u20004 \u20004 \u27604 \u36739 \
# ======================\
comparisons <- list(\
  c("edQTL", "eQTL"),\
  c("edQTL", "sQTL"),\
  c("edQTL", "pQTL"),\
  c("eQTL", "sQTL"),\
  c("eQTL", "pQTL"),\
  c("sQTL", "pQTL")\
)\
\
# ======================\
# 5\uc0\u65039 \u8419  \u33707 \u20848 \u36842 \u37197 \u33394 \
# ======================\
cols <- c(\
  "edQTL" = "#8DA0A6",\
  "eQTL"  = "#A3B18A",\
  "sQTL"  = "#C9ADA7",\
  "pQTL"  = "#9A8C98"\
)\
\
# ======================\
# 6\uc0\u65039 \u8419  \u20316 \u22270 \u65288 \u26368 \u32456 \u31283 \u23450 \u29256 \u55357 \u56613 \u65289 \
# ======================\
p <- ggplot(dat, aes(x = type, y = effect, fill = type)) +\
\
  # violin\
  geom_violin(alpha = 0.5, trim = TRUE) +\
\
  # box\
  geom_boxplot(width = 0.1, outlier.shape = NA) +\
\
  # median\
  stat_summary(\
    fun = median,\
    geom = "point",\
    shape = 21,\
    size = 3,\
    fill = "white"\
  ) +\
\
  # mean \uc0\u26631 \u27880 \
  geom_text(\
    data = mean_df,\
    aes(\
      x = type,\
      y = mean_effect + 0.03,\
      label = sprintf("mean\\n%.3f", mean_effect)\
    ),\
    size = 4\
  ) +\
\
  # \uc0\u55357 \u56613  \u26174 \u33879 \u24615 \u65288 \u20851 \u38190 \u20462 \u22797 \u65289 \
  stat_compare_means(\
    comparisons = comparisons,\
    method = "wilcox.test",\
    label = "p.signif",\
    hide.ns = FALSE,\
    size = 5,\
    step.increase = 0.05   # \uc0\u33258 \u21160 \u24448 \u19978 \u21472 \
  ) +\
\
  # \uc0\u39068 \u33394 \
  scale_fill_manual(values = cols) +\
\
  # \uc0\u55357 \u56613  \u32473 \u26174 \u33879 \u24615 \u30041 \u31354 \u38388 \u65288 \u20851 \u38190 \u65289 \
  coord_cartesian(ylim = c(0, 1.5)) +\
\
  theme_classic() +\
  theme(\
    legend.position = "none",\
    axis.text.x  = element_text(size = 14),\
    axis.text.y  = element_text(size = 14),\
    axis.title.y = element_text(size = 15),\
    plot.title   = element_text(size = 16, hjust = 0.5),\
\
    # \uc0\u55357 \u56613  \u39030 \u37096 \u30041 \u30333 \u65288 \u38450 \u25380 \u65289 \
    plot.margin = margin(t = 30, r = 10, b = 10, l = 10)\
  ) +\
\
  labs(\
    x = "",\
    y = "|Effect size|",\
    title = "Effect size comparison across QTL types"\
  )\
# ======================\
# 7\uc0\u65039 \u8419  \u36755 \u20986 \
# ======================\
ggsave(\
  file.path(outdir, "effect_size_comparison_pair_morandi.png"),\
  p,\
  width = 5,\
  height = 7,\
  dpi = 300\
)\
\
ggsave(\
  file.path(outdir, "effect_size_comparison_pair_morandi.pdf"),\
  p,\
  width = 7,\
  height =5,\
