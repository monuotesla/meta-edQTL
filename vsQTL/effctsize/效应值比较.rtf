library(data.table)\
library(ggplot2)\
library(ggpubr)\
\
# ======================\
# 
\f1 \'ca\'e4\'b3\'f6\'c4\'bf\'c2\'bc
\f0 \
# ======================\
outdir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/effcet"\
dir.create(outdir, showWarnings = FALSE, recursive = TRUE)\
\
# ======================\
# 1. 
\f1 \'b6\'c1\'c8\'eb\'ca\'fd\'be\'dd
\f0  & |effect|\
# ======================\
\
# edQTL\
ed <- fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/edqtl.significant.coloc.withAnno.txt")\
ed_eff <- data.table(type = "edQTL", effect = abs(as.numeric(ed[[5]])))\
\
# pQTL\
pq <- fread(\
  "/gpfs/hpc/home/chenchao/mayinuo/edqtl/pQTL/protein_qtl.FDR0.05.allchr.txt",\
  header = FALSE\
)\
pq_eff <- data.table(type = "pQTL", effect = abs(as.numeric(pq[[14]])))\
\
# eQTL\
eq <- fread(\
  "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/eqtl.nominal.chrall.sig.symbol",\
  header = FALSE\
)\
eq_eff <- data.table(type = "eQTL", effect = abs(as.numeric(eq[[14]])))\
\
# 
\f1 \'ba\'cf\'b2\'a2
\f0 \
dat <- rbind(ed_eff, pq_eff, eq_eff)\
dat <- dat[!is.na(effect)]\
\
# ======================\
# 2. 
\f1 \'bc\'c6\'cb\'e3\'be\'f9\'d6\'b5\'b2\'a2\'b0\'b4\'b4\'d3\'b8\'df\'b5\'bd\'b5\'cd\'c5\'c5\'d0\'f2
\f0 \
# ======================\
mean_df <- dat[, .(mean_effect = mean(effect)), by = type]\
mean_df <- mean_df[order(-mean_effect)]\
\
# 
\f1 \'c9\'e8\'d6\'c3
\f0  factor 
\f1 \'cb\'b3\'d0\'f2
\f0 \
dat[, type := factor(type, levels = mean_df$type)]\
\
# ======================\
# 3. 
\f1 \'c1\'bd\'c1\'bd\'b1\'c8\'bd\'cf
\f0 \
# ======================\
comparisons <- list(\
  c("edQTL", "eQTL"),\
  c("edQTL", "pQTL"),\
  c("eQTL", "pQTL")\
)\
\
# ======================\
# 4. 
\f1 \'d7\'f7\'cd\'bc\'a3\'a8\'d0\'de\'d5\'fd\'ba\'f3\'b5\'c4\'b0\'e6\'b1\'be\'a3\'a9
\f0 \
# ======================\
p <- ggplot(dat, aes(x = type, y = effect)) +\
  geom_boxplot(\
    width = 0.55,\
    fill = "grey85",\
    outlier.shape = NA,\
    size = 0.8\
  ) +\
\
  # 
\f1 \'be\'f9\'d6\'b5\'b5\'e3
\f0 \
  geom_point(\
    data = mean_df,\
    aes(x = type, y = mean_effect),\
    color = "red",\
    size = 3.5\
  ) +\
\
  # 
\f1 \'be\'f9\'d6\'b5\'ce\'c4\'d7\'d6
\f0 \
  geom_text(\
    data = mean_df,\
    aes(\
      x = type,\
      y = mean_effect,\
      label = sprintf("mean = %.3f", mean_effect)\
    ),\
    vjust = -1.1,\
    size = 5\
  ) +\
\
  # 
\f1 \'cf\'d4\'d6\'f8\'d0\'d4\'b1\'ea\'d7\'a2
\f0 \
  stat_compare_means(\
    comparisons = comparisons,\
    method = "wilcox.test",\
    label = "p.signif",\
    hide.ns = TRUE,\
    size = 6,\
    tip.length = 0.01\
  ) +\
\
  # 
\f1 \'bf\'d8\'d6\'c6
\f0  y 
\f1 \'d6\'e1\'b8\'df\'b6\'c8
\f0 \
  coord_cartesian(ylim = c(0, 0.8)) +\
\
  theme_classic() +\
  theme(\
    plot.title = element_text(size = 16, hjust = 0.5),\
    axis.title.y = element_text(size = 16),\
    axis.text.x  = element_text(size = 15),\
    axis.text.y  = element_text(size = 15),\
    plot.margin = margin(t = 20, r = 10, b = 10, l = 10)\
  ) +\
  labs(\
    x = "",\
    y = "|Effect size|",\
    title = "Comparison of absolute effect sizes across QTL types"\
  )\
\
# ======================\
# 5. 
\f1 \'ca\'e4\'b3\'f6
\f0 \
# ======================\
ggsave(\
  file.path(outdir, "abs_effect_size_comparison_clean.png"),\
  p,\
  width = 7,\
  height = 5,\
  dpi = 300\
)\
\
ggsave(\
  file.path(outdir, "abs_effect_size_comparison_clean.pdf"),\
  p,\
  width = 7,\
  height = 5\
)\
