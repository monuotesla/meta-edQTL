# 1\uc0\u65039 \u8419  \u35835 \u25968 \u25454 \
# =========================\
ed <- scan("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/ed.uniq", what="char")\
s  <- scan("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/s.uniq",  what="char")\
e  <- scan("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/eq.uniq",  what="char")\
p  <- scan("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/p.uniq",  what="char")\
\
# =========================\
# 2\uc0\u65039 \u8419  \u23450 \u20041 \u32972 \u26223 \u65288 \u38750 \u24120 \u20851 \u38190 \u65289 \
# =========================\
bg <- unique(c(ed, s, e, p))\
\
# =========================\
# 3\uc0\u65039 \u8419  \u23553 \u35013 \u20989 \u25968 \
# =========================\
run_fisher <- function(set1, set2, name1, name2, bg) \{\
\
  a <- length(intersect(set1, set2))\
  b <- length(setdiff(set1, set2))\
  c <- length(setdiff(set2, set1))\
  d <- length(bg) - (a + b + c)\
\
  mat <- matrix(c(a,b,c,d), nrow=2)\
\
  res <- fisher.test(mat)\
\
  data.frame(\
    comparison = paste(name1, "vs", name2),\
    overlap = a,\
    set1_size = length(set1),\
    set2_size = length(set2),\
    odds_ratio = res$estimate,\
    p_value = res$p.value\
  )\
\}\
\
# =========================\
# 4\uc0\u65039 \u8419  \u19977 \u20010 \u27604 \u36739 \
# =========================\
res1 <- run_fisher(ed, s, "ed", "s", bg)\
res2 <- run_fisher(ed, e, "ed", "e", bg)\
res3 <- run_fisher(ed, p, "ed", "p", bg)\
\
# =========================\
# 5\uc0\u65039 \u8419  \u21512 \u24182 \u32467 \u26524 \
# =========================\
final_res <- rbind(res1, res2, res3)\
\
# \uc0\u25490 \u24207 \u65288 \u25353 \u26174 \u33879 \u24615 \u65289 \
final_res <- final_res[order(final_res$p_value), ]\
\
print(final_res)\
\
# =========================\
# 6\uc0\u65039 \u8419  \u20445 \u23384 \
# =========================\
write.table(\
  final_res,\
  "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/ed_vs_other_fisher.txt",\
  sep = "\\t",\
  quote = FALSE,\
  row.names = FALSE\
)\
\
