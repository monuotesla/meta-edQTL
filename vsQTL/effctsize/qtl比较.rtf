library(data.table)\
library(ggplot2)\
\
# =========================\
# 1\uc0\u65039 \u8419  \u35835 \u21462 \u20989 \u25968 \
# =========================\
read_set <- function(f) unique(scan(f, what="char"))\
\
# =========================\
# 2\uc0\u65039 \u8419  \u25968 \u25454 \u35835 \u21462 \
# =========================\
ed_gene <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/ed.uniq")\
s_gene  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/s.uniq")\
e_gene  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/eq.uniq")\
p_gene  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/p.uniq")\
\
ed_snp <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/snp/edSNP.uniq")\
s_snp  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/snp/sSNP.uniq")\
e_snp  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/snp/eSNP.uniq")\
p_snp  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/snp/pSNP.uniq")\
\
ed_pair <- fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/pair/edPair.uniq")\
s_pair  <- fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/pair/sPair.uniq")\
e_pair  <- fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/pair/ePair.uniq")\
p_pair  <- fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/pair/pPair.uniq")\
\
# =========================\
# 3\uc0\u65039 \u8419  overlap\u20989 \u25968 \u65288 \u20462 \u27491 pair\u55357 \u56613 \u65289 \
# =========================\
ratio_n <- function(a, b) \{\
  inter <- intersect(a, b)\
  list(r = length(inter) / length(a), n = length(inter))\
\}\
\
pair_ratio_n <- function(a, b) \{\
  a_key <- unique(paste(a[[1]], a[[2]]))\
  b_key <- unique(paste(b[[1]], b[[2]]))\
  inter <- intersect(a_key, b_key)\
\
  list(\
    r = length(inter) / length(a_key),\
    n = length(inter)\
  )\
\}\
\
# =========================\
# 4\uc0\u65039 \u8419  \u35745 \u31639 unique pair\u24635 \u25968 \u65288 \u20851 \u38190 \u55357 \u56613 \u65289 \
# =========================\
n_ed_pair <- length(unique(paste(ed_pair[[1]], ed_pair[[2]])))\
n_s_pair  <- length(unique(paste(s_pair[[1]], s_pair[[2]])))\
n_e_pair  <- length(unique(paste(e_pair[[1]], e_pair[[2]])))\
n_p_pair  <- length(unique(paste(p_pair[[1]], p_pair[[2]])))\
\
# =========================\
# 5\uc0\u65039 \u8419  \u26500 \u24314 \u30697 \u38453 \
# =========================\
build_row <- function(type, level, res)\{\
  data.table(Type=type, Level=level, value=res$r, overlap_n=res$n)\
\}\
\
mat <- rbindlist(list(\
\
  build_row("eQTL","Gene", ratio_n(ed_gene, e_gene)),\
  build_row("eQTL","SNP",  ratio_n(ed_snp,  e_snp)),\
  build_row("eQTL","Pair", pair_ratio_n(ed_pair, e_pair)),\
\
  build_row("sQTL","Gene", ratio_n(ed_gene, s_gene)),\
  build_row("sQTL","SNP",  ratio_n(ed_snp,  s_snp)),\
  build_row("sQTL","Pair", pair_ratio_n(ed_pair, s_pair)),\
\
  build_row("pQTL","Gene", ratio_n(ed_gene, p_gene)),\
  build_row("pQTL","SNP",  ratio_n(ed_snp,  p_snp)),\
  build_row("pQTL","Pair", pair_ratio_n(ed_pair, p_pair))\
\
))\
\
# =========================\
# 6\uc0\u65039 \u8419  \u27178 \u36724 \u65288 edQTL\u65289 \
# =========================\
mat$Level <- factor(mat$Level, levels=c("Gene","SNP","Pair"))\
levels(mat$Level) <- c(\
  paste0("edGene\\n(n=", length(ed_gene), ")"),\
  paste0("edSNP\\n(n=", length(ed_snp), ")"),\
  paste0("edPair\\n(n=", n_ed_pair, ")")\
)\
\
# =========================\
# 7\uc0\u65039 \u8419  \u32437 \u36724 \u65288 \u25442 \u34892 +\u23436 \u25972 \u20449 \u24687 \u55357 \u56613 \u65289 \
# =========================\
mat$Type <- factor(mat$Type, levels=c("eQTL","sQTL","pQTL"))\
levels(mat$Type) <- c(\
  paste0("eQTL\\nGene:", length(e_gene),\
         "\\nSNP:", length(e_snp),\
         "\\nPair:", n_e_pair),\
\
  paste0("sQTL\\nGene:", length(s_gene),\
         "\\nSNP:", length(s_snp),\
         "\\nPair:", n_s_pair),\
\
  paste0("pQTL\\nGene:", length(p_gene),\
         "\\nSNP:", length(p_snp),\
         "\\nPair:", n_p_pair)\
)\
\
# =========================\
# 8\uc0\u65039 \u8419  \u20316 \u22270 \
# =========================\
p <- ggplot(mat, aes(x=Level, y=Type, fill=value)) +\
\
  geom_tile(color="black", alpha=0.8) +\
\
  geom_text(\
    aes(label = paste0(sprintf("%.2f", value), "\\n(", overlap_n, ")")),\
    size = 5,\
    fontface = "bold",\
    lineheight = 0.9\
  ) +\
\
  scale_fill_gradient(\
    low = "#deebf7",\
    high = "#08519c",\
    name = "Overlap ratio"\
  ) +\
\
  theme_classic(base_size = 14) +\
\
  theme(\
    axis.text.x = element_text(size=13),\
    axis.text.y = element_text(size=12),\
    plot.title = element_text(hjust=0.5)\
  ) +\
\
  labs(\
    x = "edQTL (Gene / SNP / Pair)",\
    y = "QTL types",\
    title = "Overlap between edQTL and other QTL types"\
  )\
\
# =========================\
# 9\uc0\u65039 \u8419  \u20445 \u23384 \u65288 \u26356 \u23485 \u55357 \u56613 \u65289 \
# =========================\
ggsave(\
  "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/result/heatmap_overlap.pdf",\
  p,\
  width = 8,\
  height = 5\
)\
