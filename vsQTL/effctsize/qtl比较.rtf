library(data.table)\
library(ggplot2)\
library(ggpubr)\
library(dplyr)\
\
# ======================\
# \uc0\u36755 \u20986 \u30446 \u24405 \
# ======================\
outdir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/pli/"\
dir.create(outdir, showWarnings = FALSE, recursive = TRUE)\
\
# ======================\
# 1\uc0\u65039 \u8419  \u35835 \u21462 \u20989 \u25968 \
# ======================\
read_set <- function(f) unique(scan(f, what="char"))\
\
# ======================\
# 2\uc0\u65039 \u8419  \u35835 \u21462  gene\
# ======================\
ed_gene <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/ed.uniq")\
s_gene  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/s.uniq")\
e_gene  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/eq.uniq")\
p_gene  <- read_set("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/gene/p.uniq")\
\
# ======================\
# 3\uc0\u65039 \u8419  \u35835 \u21462  pLI\
# ======================\
pli <- fread("/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/pli/exac_gene_pLI.txt",\
             col.names = c("gene","pLI"))\
\
pli <- pli %>%\
  distinct(gene, .keep_all = TRUE)\
\
# ======================\
# 4\uc0\u65039 \u8419  \u21305 \u37197 \u20989 \u25968 \
# ======================\
get_pli <- function(gene_vec, label)\{\
  data.table(gene = gene_vec) %>%\
    inner_join(pli, by="gene") %>%\
    filter(pLI > 0) %>%\
    mutate(group = label)\
\}\
\
# ======================\
# 5\uc0\u65039 \u8419  \u26500 \u24314 \u25968 \u25454 \
# ======================\
df <- rbind(\
  get_pli(ed_gene, "edGene"),\
  get_pli(e_gene,  "eGene"),\
  get_pli(s_gene,  "sGene"),\
  get_pli(p_gene,  "pGene")\
)\
\
df$group <- factor(df$group, levels = c("edGene","eGene","sGene","pGene"))\
\
# ======================\
# 6\uc0\u65039 \u8419  \u35745 \u31639 \u22343 \u20540 \
# ======================\
mean_df <- df %>%\
  group_by(group) %>%\
  summarise(mean_pLI = mean(pLI), .groups = "drop")\
\
# ======================\
# 7\uc0\u65039 \u8419  \u20004 \u20004 \u27604 \u36739 \
# ======================\
comparisons <- list(\
  c("edGene","eGene"),\
  c("edGene","sGene"),\
  c("edGene","pGene"),\
  c("eGene","sGene"),\
  c("eGene","pGene"),\
  c("sGene","pGene")\
)\
\
# ======================\
# 8\uc0\u65039 \u8419  \u33707 \u20848 \u36842 \u37197 \u33394 \
# ======================\
cols <- c(\
  "edGene" = "#8DA0A6",\
  "eGene"  = "#A3B18A",\
  "sGene"  = "#C9ADA7",\
  "pGene"  = "#9A8C98"\
)\
\
# ======================\
# 9\uc0\u65039 \u8419  \u20316 \u22270 \u65288 \u26368 \u32456 \u29256 \u55357 \u56613 \u65289 \
# ======================\
p <- ggplot(df, aes(x = group, y = pLI, fill = group)) +\
\
  geom_violin(alpha = 0.5, trim = TRUE) +\
\
  geom_boxplot(width = 0.1, outlier.shape = NA) +\
\
  stat_summary(fun = median,\
               geom = "point",\
               shape = 21,\
               size = 3,\
               fill = "white") +\
\
  # \uc0\u55357 \u56613  \u22343 \u20540 \u26631 \u27880 \
  geom_text(\
    data = mean_df,\
    aes(\
      x = group,\
      y = mean_pLI + 0.05,\
      label = sprintf("mean\\n%.3f", mean_pLI)\
    ),\
    size = 4\
  ) +\
\
  stat_compare_means(\
    comparisons = comparisons,\
    method = "wilcox.test",\
    label = "p.signif",\
    hide.ns = FALSE,\
    size = 5\
  ) +\
\
  scale_fill_manual(values = cols) +\
\
  theme_classic() +\
  theme(\
    axis.text = element_text(size = 14),\
    axis.title = element_text(size = 16),\
    legend.position = "none",\
    plot.title = element_text(hjust = 0.5)\
  ) +\
\
  labs(\
    x = "Gene groups",\
    y = "pLI score",\
    title = "Comparison of gene constraint across QTL types"\
  )\
\
# ======================\
# \uc0\u55357 \u56607  \u36755 \u20986 \
