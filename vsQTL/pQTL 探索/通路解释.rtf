library(data.table)\
library(clusterProfiler)\
library(org.Hs.eg.db)\
library(ggplot2)\
\
# -------------------------------\
# paths\
# -------------------------------\
infile <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/edqtl_with_pqtl_flag_and_beta.clean.txt"\
outdir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/vsPQTL/GO_enrichment/"\
\
dir.create(outdir, recursive = TRUE, showWarnings = FALSE)\
\
# -------------------------------\
# load data\
# -------------------------------\
df <- fread(infile)\
\
# gene sets\
genes_overlap <- unique(df[ispQTL == 1 & gene_name != "", gene_name])\
genes_edonly  <- unique(df[ispQTL == 0 & gene_name != "", gene_name])\
\
# -------------------------------\
# SYMBOL -> ENTREZID\
# -------------------------------\
conv_overlap <- bitr(\
  genes_overlap,\
  fromType = "SYMBOL",\
  toType = "ENTREZID",\
  OrgDb = org.Hs.eg.db\
)\
\
conv_edonly <- bitr(\
  genes_edonly,\
  fromType = "SYMBOL",\
  toType = "ENTREZID",\
  OrgDb = org.Hs.eg.db\
)\
\
# -------------------------------\
# GO enrichment (BP)\
# -------------------------------\
ego_overlap <- enrichGO(\
  gene          = conv_overlap$ENTREZID,\
  OrgDb         = org.Hs.eg.db,\
  ont           = "BP",\
  pAdjustMethod = "BH",\
  readable      = TRUE\
)\
\
ego_edonly <- enrichGO(\
  gene          = conv_edonly$ENTREZID,\
  OrgDb         = org.Hs.eg.db,\
  ont           = "BP",\
  pAdjustMethod = "BH",\
  readable      = TRUE\
)\
\
# save full tables\
write.table(\
  ego_overlap@result,\
  file = paste0(outdir, "GO_BP_overlap_full.txt"),\
  sep = "\\t",\
  quote = FALSE,\
  row.names = FALSE\
)\
\
write.table(\
  ego_edonly@result,\
  file = paste0(outdir, "GO_BP_edonly_full.txt"),\
  sep = "\\t",\
  quote = FALSE,\
  row.names = FALSE\
)\
\
# -------------------------------\
# take top 5\
# -------------------------------\
top_overlap <- head(ego_overlap@result, 5)\
top_overlap$Group <- "Overlap (edQTL+pQTL)"\
\
top_edonly <- head(ego_edonly@result, 5)\
top_edonly$Group <- "edQTL only"\
\
top_all <- rbind(top_overlap, top_edonly)\
\
# -------------------------------\
# plot: Top5 dotplot\
# -------------------------------\
p <- ggplot(\
  top_all,\
  aes(\
    x = Group,\
    y = reorder(Description, Count),\
    size = Count,\
    color = p.adjust\
  )\
) +\
  geom_point() +\
  scale_color_continuous(low = "red", high = "blue", name = "adj.P") +\
  theme_classic() +\
  ylab("GO Biological Process") +\
  xlab("") +\
  ggtitle("Top enriched GO terms (Top 5 per group)")\
\
ggsave(\
  filename = paste0(outdir, "GO_BP_Top5_overlap_vs_edonly.pdf"),\
  plot = p,\
  width = 7,\
  height = 4\
)\
\
cat("GO enrichment finished.\\nResults saved in:\\n", outdir, "\\n")\
\
