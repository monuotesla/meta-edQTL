library(data.table)\
library(ggplot2)\
\
# paths\
infile <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/edqtl_with_pqtl_flag_and_beta.clean.txt"\
outdir <- "/gpfs/hpc/home/chenchao/mayinuo/edqtl/vsQTL/vsPQTL/"\
\
dir.create(outdir, recursive = TRUE, showWarnings = FALSE)\
\
# load data\
df <- fread(infile)\
df <- df[!is.na(beta_ed)]\
\
df[, group := ifelse(ispQTL == 1,\
                     "Overlap (edQTL+pQTL)",\
                     "Background (edQTL only)")]\
\
df[, abs_beta_ed := abs(beta_ed)]\
\
# -------------------------------\
# statistics\
# -------------------------------\
mean_df <- df[, .(\
  mean_abs_beta_ed = mean(abs_beta_ed)\
), by = group]\
\
wilcox_res <- wilcox.test(abs_beta_ed ~ group, data = df)\
pval <- wilcox_res$p.value\
pval_label <- paste0("Wilcoxon p = ", formatC(pval, format = "e", digits = 2))\
\
# y position for text\
y_max <- max(df$abs_beta_ed) * 1.1\
\
# -------------------------------\
# plot\
# -------------------------------\
p <- ggplot(df, aes(x = group, y = abs_beta_ed, fill = group)) +\
  geom_boxplot(outlier.shape = NA, alpha = 0.7) +\
  theme_classic() +\
  theme(\
    legend.position = "none",\
    axis.title.x = element_blank()\
  ) +\
  ylab("|beta_ed|") +\
  geom_text(\
    data = mean_df,\
    aes(x = group,\
        y = mean_abs_beta_ed,\
        label = paste0("mean = ", round(mean_abs_beta_ed, 3))),\
    vjust = -1,\
    size = 3.5\
  ) +\
  annotate(\
    "text",\
    x = 1.5,\
    y = y_max,\
    label = pval_label,\
    size = 4\
  )\
\
ggsave(\
  filename = paste0(outdir, "abs_beta_ed_boxplot_mean_p_overlap_vs_background.pdf"),\
  plot = p,\
  width = 5,\
  height = 4\
)\
\
cat("Done. Figure saved in:\\n", outdir, "\\n")\
\
