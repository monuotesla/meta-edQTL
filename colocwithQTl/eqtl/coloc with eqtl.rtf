cat > liftover_1000GEAS_maf_hg19_to_hg38.sh << 'EOF'\
#!/usr/bin/env bash\
\
IN_FRQ="/gpfs/hpc/home/chenchao/hanc/database/1000G_Phase3_EAS_plinkfiles/1000GEAS.frq"\
OUT_DIR="/gpfs/hpc/home/chenchao/mayinuo/edqtl/coloc/witheQTL"\
CHAIN="/gpfs/hpc/home/chenchao/mayinuo/hg38/GRCh37_to_GRCh38.chain"\
\
mkdir -p "$OUT_DIR"\
\
# 1. \uc0\u20174  frq \u26500 \u24314  hg19 bed\
awk 'NR>1\{\
    split($2,a,"_");           # a[1]=chr, a[2]=pos\
    chr=a[1]; pos=a[2];\
    if(chr !~ /^chr/) chr="chr"chr;\
    print chr, pos-1, pos, $2\
\}' OFS="\\t" "$IN_FRQ" > "$OUT_DIR/1000GEAS.hg19.bed"\
\
# 2. liftOver \uc0\u21040  hg38\
liftOver \\\
  "$OUT_DIR/1000GEAS.hg19.bed" \\\
  "$CHAIN" \\\
  "$OUT_DIR/1000GEAS.hg38.bed" \\\
  "$OUT_DIR/1000GEAS.hg38.failed"\
\
# 3. \uc0\u29983 \u25104  hg19_id -> hg38_id \u26144 \u23556 \
awk -v OFS="\\t" '\{\
    old=$4;\
    split(old,a,"_");          # chr pos ref alt\
    new_pos=$3;\
    new_id=a[1]"_"new_pos"_"a[3]"_"a[4];\
    print old, new_id\
\}' "$OUT_DIR/1000GEAS.hg38.bed" > "$OUT_DIR/map_1000GEAS_hg19_to_hg38.txt"\
\
# 4. \uc0\u22238 \u20889  frq\u65292 \u26367 \u25442 \u20026  hg38 \u22352 \u26631 \
awk -F'\\t' -v OFS='\\t' '\
    FNR==NR \{ map[$1]=$2; next \}\
    NR==1 \{ print; next \}\
    \{\
        old_id=$2;\
        if(!(old_id in map)) next;\
        $2=map[old_id];\
        print\
    \}\
' "$OUT_DIR/map_1000GEAS_hg19_to_hg38.txt" \\\
  "$IN_FRQ" > "$OUT_DIR/1000GEAS.hg38.frq"\
EOF\
