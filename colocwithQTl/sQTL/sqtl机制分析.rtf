\
top_80_pph4 <- head(sorted_results, 80)\
sig_edsites <- top_80_pph4$edsite\
\
lead_snp_list <- lapply(sig_edsites, function(site)\{\
\
  # 
\f2 1\uc0\u65039 \u8419 
\f0  locus
\f1 \'b6\'a8\'ce\'bb
\f0 \
  edsite_info <- eqtl_full[eqtl_full$edsite == site, ][1, ]\
\
  if (nrow(edsite_info) == 0 || is.na(edsite_info$site_chr)) return(NULL)\
\
  chr_k <- edsite_info$site_chr\
  pos_k <- edsite_info$site_pos\
\
  region_start <- pos_k - window\
  region_end   <- pos_k + window\
\
  # 
\f2 2\uc0\u65039 \u8419 
\f0  eqtl 
\f1 \'c7\'f8\'d3\'f2\'a3\'a8\'b9\'d8\'bc\'fc\'d0\'de\'d5\'fd\'a3\'a9
\f0 \
  eqtl_reg <- eqtl_full[\
    eqtl_full$edsite == site &\
    eqtl_full$snp_chr == chr_k &\
    eqtl_full$snp_pos >= region_start &\
    eqtl_full$snp_pos <= region_end,\
  ]\
\
  if (nrow(eqtl_reg) < 2) return(NULL)\
\
  # 
\f2 3\uc0\u65039 \u8419 
\f0  gwas\
  gwas_reg <- gwas[\
    gwas$snp_chr == chr_k &\
    gwas$snp_pos >= region_start &\
    gwas$snp_pos <= region_end,\
  ]\
\
  if (nrow(gwas_reg) < 2) return(NULL)\
\
  # 
\f2 4\uc0\u65039 \u8419 
\f0  SNP
\f1 \'bd\'bb\'bc\'af
\f0 \
  snps_common <- intersect(gwas_reg$eSNP, eqtl_reg$eSNP)\
  if (length(snps_common) < 2) return(NULL)\
\
  gwas_use <- gwas_reg[match(snps_common, gwas_reg$eSNP), ]\
  eqtl_use <- eqtl_reg[match(snps_common, eqtl_reg$eSNP), ]\
\
  # 
\f2 5\uc0\u65039 \u8419 
\f0  coloc\
  res <- coloc.abf(\
    dataset1 = list(pvalues = gwas_use$pval, type = "quant", N = 546, snp = snps_common),\
    dataset2 = list(pvalues = eqtl_use$p.value, type = "quant", N = 546, snp = snps_common),\
    MAF = gwas_use$maf\
  )\
\
  snp_res <- res$results\
\
  if (is.null(snp_res) || nrow(snp_res) == 0) return(NULL)\
\
  idx <- which.max(snp_res$SNP.PP.H4)\
  if (length(idx) == 0) return(NULL)\
\
  data.frame(\
    edsite = site,\
    lead_snp = snp_res$snp[idx],\
    PP.H4 = snp_res$SNP.PP.H4[idx],\
    stringsAsFactors = FALSE\
  )\
\})\
\
