awk -F'\\t' -v OFS='\\t' '\
\
# =========================\
# 1\uc0\u65039 \u8419  sQTL\u65306 \u24314 \u31435  SNP+gene \u8594  intron \u20449 \u24687 \u32034 \u24341 \
# =========================\
NR==FNR \{\
  snp  = $8\
  gene = $NF\
\
  # \uc0\u35299 \u26512  intron \u21306 \u38388 \
  split($1, a, "|")\
  split(a[2], b, ":")\
\
  chr   = b[1]\
  start = b[2]\
  end   = b[3]\
\
  key = snp "|" gene\
  info[key] = info[key] chr ":" start ":" end ":" $14 ":" $12 ":" $16 ";"\
  next\
\}\
\
# =========================\
# 2\uc0\u65039 \u8419  edQTL \u20027 \u20307 \
# =========================\
FNR==1 \{\
  print $0, "sqtl_chr", "sqtl_start", "sqtl_end", \\\
             "sqtl_beta", "sqtl_p", "sqtl_q", \\\
             "dist_start", "dist_end"\
  next\
\}\
\
\{\
  edsite = $1\
  snp    = $2\
  gene   = $NF\
\
  # \uc0\u20174 \u31532 \u19968 \u21015 \u25552 \u21462  site_pos (\u20363 \u22914  chr10_593056 -> 593056)\
  split(edsite, e, "_")\
  ed_pos = e[2]\
\
  k = snp "|" gene\
\
  if (k in info) \{\
    n = split(info[k], arr, ";")\
    for (i=1; i<=n; i++) \{\
      if (arr[i] == "") continue\
\
      split(arr[i], x, ":")\
      ichr   = x[1]\
      istart = x[2]\
      iend   = x[3]\
\
      # \uc0\u35745 \u31639  edSite \u21040 \u20869 \u21547 \u23376 \u20004 \u31471 \u30340 \u30456 \u23545 \u36317 \u31163 \
      d1 = ed_pos - istart\
      d2 = ed_pos - iend\
\
      # \uc0\u11088  \u35745 \u31639 \u32477 \u23545 \u20540 \
      abs_d1 = (d1 < 0) ? -d1 : d1\
      abs_d2 = (d2 < 0) ? -d2 : d2\
\
      # \uc0\u11088  \u26680 \u24515 \u36807 \u28388 \u65306 \u21482 \u35201  edSite \u36317 \u31163 \u36215 \u22987 \u28857 \u25110 \u32456 \u27490 \u28857 \u12304 \u20219 \u19968 \u31471 \u12305 \u32477 \u23545 \u20540  <= 200bp\
      if (abs_d1 <= 200 || abs_d2 <= 200) \{\
        # \uc0\u36755 \u20986 \u21407 \u22987 \u34892  + sQTL\u20449 \u24687  + \u30456 \u23545 \u36317 \u31163 (\u24102 \u27491 \u36127 \u21495 \u65292 \u26041 \u20415 \u21518 \u32493 \u30475 \u19978 \u19979 \u28216 )\
        print $0, ichr, istart, iend, x[4], x[5], x[6], d1, d2\
      \}\
    \}\
  \}\
\}\
' \\\
