run_one_edsite <- function(site_id) \{\
\
    ## -------------------------\
    ## 1. \uc0\u21462 \u35813  edsite \u30340 \u25152 \u26377  edQTL SNP\
    ## -------------------------\
    eqtl_site <- eqtl[eqtl$eGene == site_id, ]\
\
    #if (nrow(eqtl_site) < 10) return(NULL)\
\
    chr_k <- eqtl_site$site_chr[1]\
    pos_k <- eqtl_site$site_pos[1]\
\
    region_start <- pos_k - window\
    region_end   <- pos_k + window\
\
    ## -------------------------\
    ## 2. GWAS\uc0\u65306 \u21462  edsite \'b1window\
    ## -------------------------\
    gwas_reg <- gwas[\
        gwas$chr == chr_k &\
        gwas$pos >= region_start &\
        gwas$pos <= region_end,\
    ]\
\
    if (nrow(gwas_reg) < 5) return(NULL)\
\
    ## -------------------------\
    ## 3. SNP \uc0\u20132 \u38598 \u65288 \u38750 \u24120 \u20851 \u38190 \u65289 \
    ## -------------------------\
    snps_common <- intersect(gwas_reg$SNP, eqtl_site$eSNP)\
\
   # if (length(snps_common) < 10) return(NULL)\
\
    ## \uc0\u20445 \u35777 \u39034 \u24207 \u23436 \u20840 \u19968 \u33268 \
    gwas_use <- gwas_reg[match(snps_common, gwas_reg$SNP), ]\
    eqtl_use <- eqtl_site[match(snps_common, eqtl_site$eSNP), ]\
\
    ## -------------------------\
    ## 4. coloc\
    ## -------------------------\
    coloc_res <- coloc.abf(\
        dataset1 = list(\
            pvalues = gwas_use$pval,\
            type = "cc",\
            s = 0.39,\
            N = 58140,\
            snp = snps_common\
        ),\
        dataset2 = list(\
            pvalues = eqtl_use$p.value,\
            type = "quant",\
            N = eqtl_use$V9[1],   # meta N \uc0\u21487 \u21464 \u65292 \u21512 \u27861 \
            snp = snps_common\
        ),\
        MAF = gwas_use$maf\
    )\
\
    ## -------------------------\
    ## 5. \uc0\u36820 \u22238  locus-level \u32467 \u26524 \
    ## -------------------------\
    data.frame(\
        edsite = site_id,\
        chr = chr_k,\
        pos = pos_k,\
        nsnps = coloc_res$summary["nsnps"],\
        PP.H0 = coloc_res$summary["PP.H0.abf"],\
        PP.H1 = coloc_res$summary["PP.H1.abf"],\
        PP.H2 = coloc_res$summary["PP.H2.abf"],\
        PP.H3 = coloc_res$summary["PP.H3.abf"],\
        PP.H4 = coloc_res$summary["PP.H4.abf"]\
    )\
\}\
\
library(parallel) # \uc0\u30830 \u20445  parallel \u21253 \u24050 \u21152 \u36733 \
