library(coloc)\
\
results <- list()\
\
library(parallel)\
\
\
window <- 500000\
\
run_one_lead <- function(k) \{\
\
    lead <- gwas_lead[k, ]\
\
    chr_k <- lead$chr\
    pos_k <- lead$pos\
    lead_id <- lead$SNP\
\
    region_start <- pos_k - window\
    region_end   <- pos_k + window\
\
    gwas_reg <- gwas[\
        gwas$chr == chr_k &\
        gwas$pos >= region_start &\
        gwas$pos <= region_end,\
    ]\
\
    eqtl_reg <- eqtl[\
        eqtl$chr == chr_k &\
        eqtl$pos >= region_start &\
        eqtl$pos <= region_end,\
    ]\
\
    snps_common <- intersect(gwas_reg$SNP, eqtl_reg$eSNP)\
\
    if (length(snps_common) < 2) return(NULL)\
\
    gwas_use <- gwas_reg[match(snps_common, gwas_reg$SNP), ]\
    eqtl_use <- eqtl_reg[match(snps_common, eqtl_reg$eSNP), ]\
\
    coloc_res <- coloc.abf(\
        dataset1 = list(\
            pvalues = gwas_use$pval,\
            type = "cc",\
            s = 0.39,\
            N = 58140,\
            snp = snps_common\
        ),\
        dataset2 = list(\
            pvalues = eqtl_use$p.value,\
            type = "quant",\
            N = eqtl_use$V9[1],\
            snp = snps_common\
        ),\
        MAF = gwas_use$maf\
    )\
\
    data.frame(\
        lead_snp = lead_id,\
        chr = chr_k,\
        pos = pos_k,\
        nsnps = coloc_res$summary["nsnps"],\
        PP.H0 = coloc_res$summary["PP.H0.abf"],\
        PP.H1 = coloc_res$summary["PP.H1.abf"],\
        PP.H2 = coloc_res$summary["PP.H2.abf"],\
        PP.H3 = coloc_res$summary["PP.H3.abf"],\
        PP.H4 = coloc_res$summary["PP.H4.abf"]\
    )\
\}\
\
# 
\f1 \'b8\'f9\'be\'dd\'bd\'da\'b5\'e3\'c7\'e9\'bf\'f6\'d1\'a1\'ba\'cb\'d0\'c4\'ca\'fd
