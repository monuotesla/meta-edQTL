library(qvalue)\
library(ggplot2)\
library(coloc)\
library(dplyr)\
library(gridExtra)\
library(data.table)\
\
# !!! \uc0\u20551 \u35774 \u20197 \u19979 \u20840 \u23616 \u21464 \u37327 \u24050 \u22312  R \u29615 \u22659 \u20013 \u21152 \u36733  !!!\
# eqtl_full: \uc0\u21253 \u21547 \u25152 \u26377  edQTL/eQTL \u25968 \u25454 \u30340 \u23436 \u25972 \u25968 \u25454 \u26694 \
# gwas:      \uc0\u21253 \u21547 \u25152 \u26377  GWAS \u25968 \u25454 \u30340 \u23436 \u25972 \u25968 \u25454 \u26694 \
# window:    \uc0\u23450 \u20041 \u20102 \u26597 \u25214 \u20849 \u20139  SNP \u30340 \u19978 \u19979 \u28216 \u36317 \u31163  (\u20363 \u22914  1e6)\
# -----------------------------------------------\
\
# ... (\uc0\u27719 \u24635 \u32467 \u26524 \u22788 \u29702 \u37096 \u20998 \u20445 \u25345 \u19981 \u21464 ) ...\
\
# =======================================================\
# 1. \uc0\u24490 \u29615 \u25552 \u21462  SNP \u35814 \u24773 \u24182 \u21333 \u29420 \u20445 \u23384 \
# =======================================================\
\
sig_genes_list <- (sig_summary$edsite)\
dir.create("Top_Coloc_Results", showWarnings = FALSE)\
\
if(length(sig_genes_list) > 0) \{\
    \
    cat("Processing individual edSite files...\\n")\
    \
    for(gene in sig_genes_list) \{\
        \
        # --- \uc0\u20851 \u38190 \u25972 \u21512 \u65306 \u25968 \u25454 \u25552 \u21462 \u21644 \u23545 \u40784  (\u22522 \u20110  run_one_edsite \u36923 \u36753 ) ---\
        \
        # 1. \uc0\u30830 \u23450  edSite \u20013 \u24515 \u21644 \u21306 \u22495  (\u20174  eqtl_full \u20013 \u25552 \u21462 )\
        edsite_info <- eqtl_full[eqtl_full$eGene == gene, ][1, ]\
        if (is.na(edsite_info$site_chr)) next # \uc0\u36339 \u36807 \u26080 \u22352 \u26631 \u30340 \u20301 \u28857 \
        \
        chr_k <- edsite_info$site_chr\
        pos_k <- edsite_info$site_pos\
        region_start <- pos_k - window\
        region_end <- pos_k + window\
\
        # 2. \uc0\u25552 \u21462  eQTL/edQTL \u25968 \u25454 \
        eqtl_reg <- eqtl_full[\
            eqtl_full$eGene == gene &\
            eqtl_full$snp_chr == chr_k &\
            eqtl_full$snp_pos >= region_start &\
            eqtl_full$snp_pos <= region_end,\
        ]\
        \
        # 3. \uc0\u25552 \u21462  GWAS \u25968 \u25454 \
        gwas_reg <- gwas[\
            gwas$chr == chr_k &\
            gwas$pos >= region_start &\
            gwas$pos <= region_end,\
        ]\
\
        # 4. SNP \uc0\u20132 \u38598 \u19982 \u23545 \u40784 \
        snps_common <- intersect(gwas_reg$SNP, eqtl_reg$eSNP)\
        if (length(snps_common) < 2) next # \uc0\u24517 \u39035 \u26377 \u36275 \u22815  SNP\
\
        gwas_use <- gwas_reg[match(snps_common, gwas_reg$SNP), ]\
        eqtl_use <- eqtl_reg[match(snps_common, eqtl_reg$eSNP), ]\
        \
        # \uc0\u23558  sub_data \u26367 \u25442 \u20026  eqtl_use/gwas_use \u30340 \u32452 \u21512 \u65292 \u29992 \u20110  Coloc \u36755 \u20837 \
        \
        # --- 5. \uc0\u36816 \u34892  coloc ---\
        \
        # D1=GWAS, D2=eQTL\uc0\u12290 \u21442 \u25968 \u19982  run_one_edsite \u20445 \u25345 \u19968 \u33268 \u12290 \
        # coloc \uc0\u32467 \u26524 \
result <- coloc.abf(\
  dataset1 = list(\
    pvalues = gwas_use$pval,\
    type = "cc",\
    s = 0.39,\
    N = 58140,\
    snp = snps_common\
  ),\
  dataset2 = list(\
    pvalues = eqtl_use$p.value,\
    type = "quant",\
    N = 975,\
    snp = snps_common\
  ),\
  MAF = gwas_use$maf\
)\
\
# ===== \uc0\u27491 \u30830 \u30340  SNP \u32423 \u21035 \u34920  =====\
snp_res <- result$results\
\
# \uc0\u9888 \u65039  \u19981  merge\u65281 \u30452 \u25509  cbind\u65288 \u39034 \u24207 \u24050 \u32463 \u23545 \u40784 \u65289 \
plot_df <- data.frame(\
  eSNP       = snp_res$snp,\
  BP         = gwas_use$pos,\
  GWAS_P     = gwas_use$pval,\
  EQTL_P     = eqtl_use$p.value,\
  MAF        = gwas_use$maf,\
  SNP.PP.H4  = snp_res$SNP.PP.H4\
)\
        \
        # \uc0\u25353  SNP.PP.H4 \u38477 \u24207 \u25490 \u21015  \
        snp_res_final <- plot_df[order(plot_df$SNP.PP.H4, decreasing = TRUE), ]\
        \
        # --- \uc0\u21333 \u29420 \u20445 \u23384 \u35813  edSite \u30340 \u25991 \u20214  ---\
        safe_gene_name <- gsub("[:/]", "_", gene)  \
        out_file_name <- paste0("Top_Coloc_Results/", safe_gene_name, ".coloc.txt")\
        \
        write.table(snp_res_final, file=out_file_name, sep="\\t", quote=F, row.names=F)\
    \}\
    \
    cat("All individual edSite files saved in 'Top_Coloc_Results' folder.\\n")\
    \
\} else \{\
    cat("No edSites passed the threshold.\\n")\
\}\
\
# =======================================================\
# 2. Locus \uc0\u21487 \u35270 \u21270  (\u21442 \u25968 \u32479 \u19968 \u19982 \u25968 \u25454 \u25972 \u21512 )\
# =======================================================\
\
# ... (\uc0\u22270 \u29255 \u20445 \u23384 \u30446 \u24405 \u21644  top_genes \u31579 \u36873 \u36923 \u36753 \u20445 \u25345 \u19981 \u21464 ) ...\
plot_dir="/gpfs/hpc/home/chenchao/mayinuo/edqtl/coloc/coloc1/SCZ_EAS/result/"\
\
top_genes=sig_genes_list\
if (length(top_genes) > 0) \{\
    \
    for (gene in top_genes) \{\
        \
        # --- \uc0\u20851 \u38190 \u25972 \u21512 \u65306 \u25968 \u25454 \u25552 \u21462 \u21644 \u23545 \u40784  (\u19982 \u19978 \u26041 \u36923 \u36753 \u19968 \u33268 ) ---\
        # 1. \uc0\u30830 \u23450  edSite \u20013 \u24515 \u21644 \u21306 \u22495 \
        edsite_info <- eqtl_full[eqtl_full$eGene == gene, ][1, ]\
        if (is.na(edsite_info$site_chr)) next\
        chr_k <- edsite_info$site_chr\
        pos_k <- edsite_info$site_pos\
        region_start <- pos_k - window\
        region_end <- pos_k + window\
\
        # 2. \uc0\u25552 \u21462  eQTL/edQTL \u25968 \u25454 \
        eqtl_reg <- eqtl_full[\
            eqtl_full$eGene == gene & eqtl_full$snp_chr == chr_k & eqtl_full$snp_pos >= region_start & eqtl_full$snp_pos <= region_end,\
        ]\
        \
        # 3. \uc0\u25552 \u21462  GWAS \u25968 \u25454 \
        gwas_reg <- gwas[\
            gwas$chr == chr_k & gwas$pos >= region_start & gwas$pos <= region_end,\
        ]\
\
        # 4. SNP \uc0\u20132 \u38598 \u19982 \u23545 \u40784 \
        snps_common <- intersect(gwas_reg$SNP, eqtl_reg$eSNP)\
        if (length(snps_common) < 2) next\
\
        gwas_use <- gwas_reg[match(snps_common, gwas_reg$SNP), ]\
        eqtl_use <- eqtl_reg[match(snps_common, eqtl_reg$eSNP), ]\
        \
        # 5. \uc0\u37325 \u26032 \u36816 \u34892  coloc\
        res <- coloc.abf(\
            dataset1 = list(pvalues = gwas_use$pval, type = "cc", s = 0.39, N = 58140, snp = snps_common),\
            dataset2 = list(pvalues = eqtl_use$p.value, type = "quant", N = 975, snp = snps_common),\
            MAF = gwas_use$maf\
        )\
            \
        snp_info <- res$results # \uc0\u21253 \u21547  snp \u21644  SNP.PP.H4 \u21015 \
        \
        # --- 6. \uc0\u25972 \u29702 \u32472 \u22270 \u25968 \u25454  (\u20351 \u29992 \u20132 \u38598 \u32467 \u26524 ) ---\
        plot_df <- data.frame(\
            eSNP = snps_common,\
            BP = gwas_use$pos, # \uc0\u20351 \u29992  GWAS \u30340 \u20301 \u32622 \u20449 \u24687 \u20316 \u20026  X \u36724 \
            GWAS_P = gwas_use$pval,\
            EQTL_P = eqtl_use$p.value\
        )\
        \
        # \uc0\u23558  SNP.PP.H4 \u21512 \u24182 \u22238 \u32472 \u22270 \u25968 \u25454 \
        plot_df <- merge(plot_df, snp_info[, c("snp", "SNP.PP.H4")], by.x = "eSNP", by.y = "snp")\
        \
        # \uc0\u36716 \u25442 \u20026  Mb \u21333 \u20301 \
        plot_df$BP_Mb <- plot_df$BP / 1e6\
        plot_df$SNP.PP.H4[is.na(plot_df$SNP.PP.H4)] <- 0\
        \
        # --- 2.4 \uc0\u20351 \u29992  ggplot2 \u32472 \u22270  ---\
        \
        # \uc0\u23450 \u20041 \u23376 \u22270  1: GWAS\
        p1 <- ggplot(plot_df, aes(x = BP_Mb, y = -log10(GWAS_P))) + # \uc0\u20351 \u29992  GWAS_P\
            geom_point(aes(color = SNP.PP.H4, size = SNP.PP.H4), alpha = 0.8) +\
            scale_color_gradient(low = "grey70", high = "red", limits = c(0, 1), name = "P(Causal)") +\
            scale_size_continuous(range = c(1.5, 4), guide = "none") +\
            labs(title = paste0(gene, " - GWAS Signal"),\
                 y = "-log10(GWAS P)", x = NULL) +\
            theme_bw() + theme(legend.position = "right", axis.text.x = element_blank())\
            \
        # \uc0\u23450 \u20041 \u23376 \u22270  2: eQTL\
        p2 <- ggplot(plot_df, aes(x = BP_Mb, y = -log10(EQTL_P))) + # \uc0\u20351 \u29992  EQTL_P\
            geom_point(aes(color = SNP.PP.H4, size = SNP.PP.H4), alpha = 0.8) +\
            scale_color_gradient(low = "grey70", high = "red", limits = c(0, 1), name = "P(Causal)") +\
            scale_size_continuous(range = c(1.5, 4), guide = "none") +\
            labs(title = paste0(gene, " - edQTL Signal"), # \uc0\u20462 \u27491 \u26631 \u39064 \u20026  edQTL\
                 y = "-log10(edQTL P)", x = paste("Position on Chr (Mb)")) +\
            theme_bw() + theme(legend.position = "right")\
            \
        # --- 2.5 \uc0\u25340 \u22270 \u24182 \u20445 \u23384  ---\
       safe_gene_name <- gsub("[:/]", "_", gene)\
        out_file <- paste0(plot_dir, safe_gene_name, "_LocusPlot.pdf")\
        \
        final_plot <- grid.arrange(p1, p2, ncol = 1, heights = c(1, 1))\
        \
        # \uc0\u20351 \u29992  ggsave \u20445 \u23384 \u25340 \u21512 \u30340 \u22270 \
        ggsave(filename = out_file, plot = final_plot, width = 8, height = 8)\
    \}\
    \
    cat("Done! All plots saved to:", plot_dir, "\\n")\
    \
\} else \{\
    cat("No edSites passed the threshold (PP.H4 > 0.75).\\n")\
\}\
