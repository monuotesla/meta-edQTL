#gene ="7_137067935"\
if(length(sig_genes_list) > 0) \{\
    \
    for(gene in sig_genes_list) \{\
        \
        # -----------------------------------------------------------\
        # A. \uc0\u25968 \u25454 \u25552 \u21462 \u19982 \u23545 \u40784  (\u20005 \u26684 \u22797 \u21046  run_one_edsite \u30340 \u36923 \u36753 )\
        # -----------------------------------------------------------\
        \
        # 1. \uc0\u30830 \u23450 \u20013 \u24515 \
        edsite_info <- eqtl_full[eqtl_full$eGene == gene, ][1, ]\
        if (is.na(edsite_info$site_chr)) \{\
            message(paste("\uc0\u36339 \u36807 :", gene, "- \u26080 \u27861 \u25214 \u21040 \u22352 \u26631 "))\
            next \
        \}\
        \
        chr_k <- edsite_info$site_chr\
        pos_k <- edsite_info$site_pos\
        region_start <- pos_k - window\
        region_end   <- pos_k + window\
\
        # 2. eQTL \uc0\u25552 \u21462 \
        eqtl_reg <- eqtl_full[\
            eqtl_full$eGene == gene &\
            eqtl_full$snp_chr == chr_k &\
            eqtl_full$snp_pos >= region_start &\
            eqtl_full$snp_pos <= region_end,\
        ]\
        if (nrow(eqtl_reg) < 2) next\
\
        # 3. GWAS \uc0\u25552 \u21462 \
        gwas_reg <- gwas[\
            gwas$chr == chr_k &\
            gwas$pos >= region_start &\
            gwas$pos <= region_end,\
        ]\
        if (nrow(gwas_reg) < 5) next\
\
        # 4. \uc0\u20851 \u38190 \u27493 \u39588 \u65306 \u20132 \u38598 \u19982 \u24378 \u21046 \u23545 \u40784  (Intersect & Match)\
       snps_common <- intersect(gwas_reg$SNP, eqtl_reg$eSNP) \
        \
        if (length(snps_common) < 2) \{\
            message(paste("\uc0\u36339 \u36807 :", gene, "- \u20849 \u29992  SNP \u23569 \u20110  2 \u20010 "))\
            next\
        \}\
\
        # *** \uc0\u26680 \u24515 \u20462 \u27491  ***\u65306 \u29983 \u25104 \u23436 \u20840 \u23545 \u40784 \u30340 \u20004 \u20010 \u20020 \u26102 \u25968 \u25454 \u26694 \
        # \uc0\u27492 \u26102  gwas_use \u21644  eqtl_use \u30340 \u34892 \u25968 \u23436 \u20840 \u30456 \u21516 \u65292 \u39034 \u24207 \u23436 \u20840 \u19968 \u33268  (\u22522 \u20110  snps_common)\
        gwas_use <- gwas_reg[match(snps_common, gwas_reg$SNP), ]\
        eqtl_use <- eqtl_reg[match(snps_common, eqtl_reg$eSNP), ]\
\
        # -----------------------------------------------------------\
        # B. \uc0\u20877 \u27425 \u36816 \u34892  Coloc \u20197 \u33719 \u21462  SNP \u32423 \u21035 \u30340  PPH4\
        # -----------------------------------------------------------\
        res <- coloc.abf(\
            dataset1 = list(\
                pvalues = gwas_use$pval, \
                type = "cc", \
                s = 0.39, \
                N = 58140, \
                snp = snps_common\
            ),\
            dataset2 = list(\
                pvalues = eqtl_use$p.value, \
                type = "quant", \
                N = 975, \
                snp = snps_common\
            ),\
            MAF = gwas_use$maf\
        )\
\
       # -----------------------------------------------------------\
        # C. \uc0\u32452 \u35013 \u32467 \u26524 \u24182 \u20445 \u23384  (\u20462 \u27491 \u21015 \u21517 \u20026  ref/alt)\
        # -----------------------------------------------------------\
        coloc_snp_res <- res$results\
        \
        # \uc0\u23433 \u20840 \u25552 \u21462  SNP.PP.H4\
        idx_in_res <- match(snps_common, coloc_snp_res$snp)\
        snp_pph4_aligned <- coloc_snp_res$SNP.PP.H4[idx_in_res]\
        \
        # \uc0\u26500 \u24314 \u26368 \u32456 \u34920 \u26684  (\u20351 \u29992 \u27491 \u30830 \u30340 \u21015 \u21517  ref \u21644  alt)\
        final_table <- data.frame(\
            snp         = snps_common,       \
            chr         = chr_k,             \
            pos         = gwas_use$pos,      \
            \
            # --- \uc0\u20462 \u27491 \u36825 \u37324  ---\
            ref         = gwas_use$ref,      # \uc0\u21407 \u20195 \u30721 \u21483  a1\u65292 \u24744 \u30340 \u26159  ref\
            alt         = gwas_use$alt,      # \uc0\u21407 \u20195 \u30721 \u21483  a2\u65292 \u24744 \u30340 \u26159  alt\
            \
            pval_gwas   = gwas_use$pval,     \
            pval_eqtl   = eqtl_use$p.value,  \
            maf         = gwas_use$maf,      \
            SNP.PP.H4   = snp_pph4_aligned   \
        )\
        \
        \
        # \uc0\u25353 \u22240 \u26524 \u27010 \u29575 \u38477 \u24207 \u25490 \u21015 \
        final_table <- final_table[order(final_table$SNP.PP.H4, decreasing = TRUE), ]\
        \
        # \uc0\u20445 \u23384 \u25991 \u20214 \
        safe_gene_name <- gsub("[:/]", "_", gene)   \
        out_file_name <- file.path(out_dir, paste0(safe_gene_name, ".coloc.txt"))\
        \
        write.table(final_table, file=out_file_name, sep="\\t", quote=F, row.names=F)\
\
