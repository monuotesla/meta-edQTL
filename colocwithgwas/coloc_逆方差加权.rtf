# (A) \uc0\u28165 \u29702 \u21015 \u34920 \u65306 \u31227 \u38500 \u25152 \u26377 \u36820 \u22238  NULL \u30340 \u20803 \u32032 \u65288 \u21363 \u20849 \u21516  SNP \u19981 \u36275 \u30340 \u22522 \u22240 \u24231 \u65289 \
